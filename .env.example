# ==========================================================================
#  Шеф-Повар AI — пример конфигурации окружения
#  Скопируйте в .env и заполните своими значениями:  cp .env.example .env
#  ВНИМАНИЕ: файл .env содержит секреты и НЕ должен попадать в git.
# ==========================================================================

# ===== TELEGRAM (обязательно) =====
# Токен бота из @BotFather
BOT_TOKEN=123456:ABC-DEF...
# Telegram ID администратора (получить у @userinfobot)
ADMIN_ID=000000000
# Публичный HTTPS-URL мини-аппа (например, https://chef.example.com)
MINI_APP_URL=https://your-domain.example.com

# ===== СЕРВЕР =====
PORT=3000

# ===== БАЗА ДАННЫХ (PostgreSQL) =====
# Вариант 1: одной строкой
DATABASE_URL=postgres://user:password@localhost:5432/chefai
# Вариант 2: по частям (используется, если DATABASE_URL не задан)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=chefai
# DB_USER=postgres
# DB_PASSWORD=change-me

# ===== ИИ: GigaChat (Сбер) =====
# Base64-строка авторизации (Client ID:Client Secret) из личного кабинета GigaChat
GIGACHAT_CREDENTIALS=base64-credentials-here

# ===== ГОЛОСОВОЙ ВВОД: Yandex SpeechKit (опционально) =====
# Без ключа голосовой ввод работает в тестовом режиме
YANDEX_API_KEY=

# ===== РЕКВИЗИТЫ ОПЛАТЫ (СБП) =====
# Не меняют способ оплаты — только реквизиты, отображаемые пользователю
SBP_PHONE=+70000000000
SBP_RECIPIENT=ФИО получателя

# ===== ЗАЩИТА ОТ АБЬЮЗА (опционально) =====
# Лимиты щедрые; реальные пользователи их не достигают.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_WINDOW_MS=60000        # окно, мс
# RATE_LIMIT_MAX=240                # общий лимит запросов к /api за окно (по IP)
# RATE_LIMIT_GENERATE_MAX=30        # лимит дорогих ИИ-запросов за окно (по пользователю)

# ===== TLS / СЕРТИФИКАТЫ (рекомендация для production) =====
# Вместо отключения проверки TLS установите корневые сертификаты Минцифры и укажите путь:
# NODE_EXTRA_CA_CERTS=/etc/ssl/certs/russian_trusted_root_ca.pem
